# Copy this file to .env and fill in your values

# Set USE_MONGO=false to run without MongoDB (local dev mode)
# Data is stored in-memory only and lost on restart
USE_MONGO=true

# MongoDB connection string (only used when USE_MONGO is not false)
MONGO_URI=mongodb://localhost:27017/maple_mini_rpg

# JWT secret key – change this in production!
JWT_SECRET=your_secret_key_here

# Server port
PORT=3000
